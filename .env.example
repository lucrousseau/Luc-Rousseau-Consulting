# Site origin for SEO (canonical, OG, sitemap). Optional: in browser and API routes
# the origin is detected from the request; this is used for SSR when no request is available.
# Example production:
NEXT_PUBLIC_DOMAIN=https://lucrousseau.com
# Example local:
# NEXT_PUBLIC_DOMAIN=http://localhost:3000

# Google Tag Manager. Defaults to GTM-NR63CJ if unset (see utils/gtm.js).
# Override for another container, or set to empty string to disable (rebuild required).
# NEXT_PUBLIC_GTM_ID=GTM-NR63CJ
