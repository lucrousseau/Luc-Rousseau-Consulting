{
  "name": "lucrousseau",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "npm run typecheck && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"**/*.scss\" --fix",
    "stylelint:check": "stylelint \"**/*.scss\"",
    "lint:scss-functions": "node scripts/check-scss-function-names.js",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "fix": "npm run format && npm run lint:fix && npm run stylelint",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "fix:security": "npm audit fix && npm run lint:fix",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate": "npm run lint && npm run format:check && npm run stylelint:check && npm run lint:scss-functions && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "classnames": "^2.5.1",
    "html-react-parser": "^6.1.4",
    "i18next": "^26.3.5",
    "image-size": "^1.2.1",
    "minireset.css": "^0.0.7",
    "next": "^16.2.10",
    "next-i18next": "^16.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "sass": "^1.101.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^16.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "22.x"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  }
}
