{
  "name": "lucrousseau",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"**/*.scss\" --fix",
    "stylelint:check": "stylelint \"**/*.scss\"",
    "lint:scss-functions": "node scripts/check-scss-function-names.js",
    "fix": "npm run format && npm run lint:fix && npm run stylelint",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "fix:security": "npm audit fix && npm run lint:fix",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate": "npm run lint && npm run format:check && npm run stylelint:check && npm run lint:scss-functions && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^1.2.2",
    "@vercel/speed-insights": "^1.0.10",
    "classnames": "^2.5.1",
    "html-react-parser": "^5.1.10",
    "i18next": "^23.11.5",
    "image-size": "^1.1.1",
    "minireset.css": "^0.0.7",
    "next": "^15.5.14",
    "next-i18next": "^15.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.1",
    "sass": "^1.97.3",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.8",
    "@babel/preset-react": "^7.24.7",
    "@next/bundle-analyzer": "^15.5.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  },
  "engines": {
    "node": "22.x"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  }
}
